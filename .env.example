# ═══════════════════════════════════════════════════════════════════════════════
# EVR Trading Bot — Ortam Değişkenleri (.env)
# ═══════════════════════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayıp değerlerini doldurun:
#   cp .env.example .env
#
# ⚠️ DİKKAT: .env dosyası gizlidir ve GitHub'a YÜKLENMEZ (.gitignore korumalı).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Güvenlik (ZORUNLU) ──────────────────────────────────────────────────────
# JWT token imzalama anahtarı. Üretmek için:
#   python -c "import secrets; print(secrets.token_hex(32))"
EVR_SECRET_KEY=BURAYA_GUCLU_BIR_SECRET_KEY_YAZIN

# Fernet şifreleme anahtarı (Production'da ZORUNLU):
# Üretmek için: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EVR_FERNET_KEY=BURAYA_FERNET_ANAHTARINI_YAZIN

# ─── Veritabanı (Docker'da otomatik, yerel geliştirmede isteğe bağlı) ────────
# PostgreSQL (Docker Compose otomatik ayarlar):
# DATABASE_URL=postgresql://evr:SIFRE@db:5432/evr_bot
# SQLite (yerel geliştirme — varsayılan):
# DATABASE_URL=sqlite:///evr_bot.db

# Docker Compose PostgreSQL şifresi (ZORUNLU — docker-compose.yml bunu okur):
POSTGRES_PASSWORD=BURAYA_GUCLU_BIR_POSTGRES_SIFRESI_YAZIN

# ─── EVR Veri Kaynağı (ZORUNLU — kmquant.com erişimi) ───────────────────────
# kmquant.com hesap bilgileri:
KMFG_EMAIL=sizin@email.com
KMFG_PASSWORD=sizin_sifreniz

# CapSolver API anahtarı (Cloudflare Turnstile bypass için):
# https://www.capsolver.com adresinden alınır
CAPSOLVER_KEY=CAP-XXXXXXXXXXXXXXXXXXXXXXX

# ─── Bybit API (İsteğe Bağlı — canlı işlem için) ────────────────────────────
# Testnet kullanmak için true yapın:
BYBIT_TESTNET=false

# ─── Web Güvenliği ──────────────────────────────────────────────────────────
# CORS izin verilen domainler (virgülle ayrılmış):
# Geliştirme:  ALLOWED_ORIGINS=*
# Canlı:       ALLOWED_ORIGINS=https://sizin-domain.com
ALLOWED_ORIGINS=*

# Ortam belirteci (production / development):
ENVIRONMENT=development

# ─── Cloudflare Tunnel (İsteğe Bağlı — ücretsiz public URL) ─────────────────
# https://dash.cloudflare.com → Zero Trust → Tunnels → Token kopyalayın
# TUNNEL_TOKEN=eyJhIjoi...
